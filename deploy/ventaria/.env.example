# Скопируйте в `.env` в каталоге деплоя на сервере (рядом с docker-compose.yml; CI файл не перезаписывает).
# Статика фронта — в ./public относительно этого каталога (см. workflow deploy-ventaria). Nginx: root → …/public, /api → 127.0.0.1:API_PUBLISH_PORT

DATABASE_URL=postgres://postgres:postgres@postgres:5432/ai_seller
JWT_SECRET=
ENCRYPTION_KEY=

# Порт процесса API внутри контейнера (и healthcheck)
API_PORT=3001
# Порт на хосте (за nginx / снаружи)
API_PUBLISH_PORT=3001
# Привязка публикации порта: 127.0.0.1 или 0.0.0.0
API_BIND=127.0.0.1
PROMETHEUS_PUBLISH_PORT=9090
PROMETHEUS_BIND=127.0.0.1
GRAFANA_PUBLISH_PORT=3060
GRAFANA_BIND=127.0.0.1
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=https://ai.ventaria.ru/grafana/
RABBITMQ_PUBLISH_PORT=5672
RABBITMQ_UI_PUBLISH_PORT=15672
RABBITMQ_BIND=127.0.0.1
# Публичный URL кабинета (используется в юридических ссылках и Telegram-боте)
WEB_PUBLIC_URL=https://ai.ventaria.ru
TELEGRAM_UPDATES_MODE=webhook
# Для общего бота (__shared__): в проде обычно false, чтобы избежать long polling.
TELEGRAM_SHARED_BOT_POLLING=false
TELEGRAM_WEBHOOK_BASE_URL=https://api.ventaria.ru

# Telegram-уведомления владельцу сервиса
GLOBAL_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# SMTP (подтверждение email, восстановление пароля, письма об оплате)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Seller

# RabbitMQ (очередь ответов из кабинета в Telegram)
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_CONVERSATIONS_REPLY_QUEUE=conversations.reply.v1
RABBITMQ_PREFETCH=10
