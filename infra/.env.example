POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_seller
DATABASE_URL=postgres://postgres:postgres@postgres:5432/ai_seller
JWT_SECRET=supersecret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
# Порты процессов внутри контейнеров
API_PORT=3001
WEB_PORT=3000
# Проброс на хост (docker compose подставляет из этого файла при `compose up` из infra/)
API_PUBLISH_PORT=3055
WEB_PUBLISH_PORT=3050
POSTGRES_PUBLISH_PORT=5452
REDIS_PUBLISH_PORT=6379
PROMETHEUS_PUBLISH_PORT=9090
LOKI_PUBLISH_PORT=3100
GRAFANA_PUBLISH_PORT=3060
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Для фронта в браузере. В Docker dev переопределяется в docker-compose.dev.yml (3001 + API_INTERNAL_URL).
NEXT_PUBLIC_API_URL=http://localhost:3001
# Публичный URL кабинета (используется, например, в Telegram для ссылок на политику данных).
WEB_PUBLIC_URL=http://localhost:3000
GLOBAL_BOT_TOKEN=
GLOBAL_BOT_SECRET=global-secret
ADMIN_TELEGRAM_CHAT_ID=

# Telegram: polling (Docker dev) или webhook (прод). При webhook после добавления токена вызывается setWebhook.
TELEGRAM_UPDATES_MODE=polling
# Публичный HTTPS URL API без слэша в конце, например https://api.example.com (для setWebhook → .../telegram/webhook)
TELEGRAM_WEBHOOK_BASE_URL=

# Timeweb Cloud AI (для ответов в Telegram через agent.call; без токена — скриптовые фразы)
TIMEWEB_AI_ACCESS_TOKEN=
TIMEWEB_AI_PROXY_SOURCE=ai-seller-api
TIMEWEB_AI_AGENT_ID=

# Timeweb S3/Object Storage
S3_ENDPOINT=
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# SMTP (подтверждение почты, восстановление пароля, письма об оплате)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Seller
