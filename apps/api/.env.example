DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_seller
JWT_SECRET=supersecret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
API_PORT=3001
API_BODY_LIMIT=150mb
GLOBAL_BOT_TOKEN=
GLOBAL_BOT_SECRET=global-secret
ADMIN_TELEGRAM_CHAT_ID=

# ЮKassa (оплата тарифов)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Куда вернуть пользователя после оплаты (добавится ?payment=success при необходимости)
YOOKASSA_RETURN_URL=http://localhost:3000/dashboard/billing
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
# SWAGGER=0 — отключить страницу /docs (по умолчанию документация включена)

# SMTP (подтверждение почты, восстановление пароля, письма об оплате)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Seller

# TELEGRAM_UPDATES_MODE=polling | webhook
# TELEGRAM_WEBHOOK_BASE_URL=https://your-public-api.example.com

# Timeweb Cloud AI (Telegram-диалог; без токена — статические ответы)
TIMEWEB_AI_ACCESS_TOKEN=
TIMEWEB_AI_PROXY_SOURCE=ai-seller-api
TIMEWEB_AI_AGENT_ID=

# Timeweb S3/Object Storage
S3_ENDPOINT=
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
